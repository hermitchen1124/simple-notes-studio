{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simple Notes Studio",
  "version": "0.1.6",
  "identifier": "io.github.hermitchen1124.simple-notes-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Simple Notes Studio",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "name": "Markdown Document",
        "ext": ["md", "markdown"],
        "role": "Editor",
        "rank": "Default"
      },
      {
        "name": "Plain Text Document",
        "ext": ["txt", "log"],
        "role": "Editor",
        "rank": "Default"
      },
      {
        "name": "JSON Document",
        "ext": ["json", "jsonl"],
        "role": "Editor",
        "rank": "Default"
      },
      {
        "name": "YAML Document",
        "ext": ["yaml", "yml"],
        "role": "Editor",
        "rank": "Default"
      },
      {
        "name": "TOML Document",
        "ext": ["toml"],
        "role": "Editor",
        "rank": "Default"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
